package com.vestbem.app.data

import com.google.firebase.auth.FirebaseAuth
import com.google.firebase.firestore.FirebaseFirestore
import com.google.firebase.firestore.Query
import kotlinx.coroutines.tasks.await
import javax.inject.Inject

data class Produto(
    val id: String = "",
    val nome: String = "",
    val preco: Double = 0.0,
    val categoria: String = "",
    val imagemUrl: String = "",
    val tamanhos: List<String> = emptyList(),
    val cores: List<String> = emptyList(),
    val estoque: Int = 0,
    val avaliacao: Double = 0.0,
    val numAvaliacoes: Int = 0
)

class FirebaseService @Inject constructor(
    private val auth: FirebaseAuth,
    private val firestore: FirebaseFirestore
) {
    
    // Autenticação
    suspend fun login(email: String, senha: String): Result<String> {
        return try {
            val result = auth.signInWithEmailAndPassword(email, senha).await()
            Result.success(result.user?.uid ?: "")
        } catch (e: Exception) {
            Result.failure(e)
        }
    }
    
    suspend fun register(email: String, senha: String, nome: String): Result<String> {
        return try {
            val result = auth.createUserWithEmailAndPassword(email, senha).await()
            result.user?.uid?.let { uid ->
                firestore.collection("users").document(uid)
                    .set(mapOf("nome" to nome, "email" to email))
            }
            Result.success(result.user?.uid ?: "")
        } catch (e: Exception) {
            Result.failure(e)
        }
    }
    
    // Catálogo em Tempo Real
    fun getProdutosStream(categoria: String? = null): Query {
        return if (categoria != null) {
            firestore.collection("produtos")
                .whereEqualTo("categoria", categoria)
                .orderBy("preco")
        } else {
            firestore.collection("produtos")
                .orderBy("nome")
        }
    }
    
    suspend fun getProdutoById(id: String): Result<Produto> {
        return try {
            val doc = firestore.collection("produtos").document(id).get().await()
            val produto = doc.toObject(Produto::class.java)?.copy(id = doc.id)
            Result.success(produto ?: Produto())
        } catch (e: Exception) {
            Result.failure(e)
        }
    }
}
